# ── LLM ──────────────────────────────────────────────────────────────────
# Free API key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key

# ── JOB SCRAPING APIS ────────────────────────────────────────────────────
# All three sources below require NO API KEY — they work out of the box.
# RemoteOK, The Muse, and Arbeitnow are all public APIs.

# ── APP CONFIG ────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                      # DEBUG | INFO | WARNING | ERROR
MAX_JOBS_PER_SOURCE=20              # Cap results per API to control cost & latency
REQUEST_TIMEOUT_SECONDS=15          # HTTP timeout for all external API calls
